{
  "name": "nightly-librarian",
  "version": "0.1.0",
  "private": true,
  "description": "Distribution coordination for the Nightly Librarian Audience Engine",
  "scripts": {
    "approval:create": "node scripts/approval.js create",
    "approval:validate": "node scripts/approval.js validate",
    "digest:import": "node scripts/digest-import.js",
    "fetch": "node src/index.js fetch",
    "report:write": "node scripts/report-write.js",
    "social:generate": "node scripts/social-generate.js",
    "triage:claim": "node src/index.js triage:claim",
    "triage:complete": "node src/index.js triage:complete",
    "triage:export": "node src/index.js triage:export",
    "triage:fail": "node src/index.js triage:fail",
    "triage:report": "node src/index.js triage:report",
    "triage:latest": "node src/index.js triage:latest",
    "migrate": "node scripts/migrate.js",
    "build:site": "node scripts/build-site.js",
    "serve": "npx serve site -p 3000 --no-clipboard",
    "synthesize:runs": "node scripts/synthesize-runs.js",
    "verify": "bash scripts/verify.sh",
    "test": "node --test test/*.test.js",
    "test-source": "node scripts/test-source.js",
    "test-all": "node scripts/test-all.js"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "cloakbrowser": "^0.3.28",
    "dotenv": "^16.4.7",
    "pg": "^8.13.1",
    "playwright-core": "^1.60.0",
    "rss-parser": "^3.13.0"
  }
}
